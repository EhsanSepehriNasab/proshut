<!DOCTYPE html>
<html lang="<%= lang %>" dir="<%= dir %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof pageTitle !== 'undefined' && pageTitle ? pageTitle + ' | ' + settings.company_short : settings.meta_title || settings.company_short %></title>
    <meta name="description" content="<%= typeof metaDesc !== 'undefined' ? metaDesc : (settings.meta_description || '') %>">
    <meta name="keywords" content="<%= settings.meta_keywords || '' %>">
    <meta name="robots" content="index, follow">
    <meta name="author" content="<%= settings.company_name %>">
    <link rel="canonical" href="<%= settings.company_en ? 'https://proshut.com' : '' %><%= currentPath %>">
    <meta name="theme-color" content="#121111">

    <!-- Open Graph -->
    <meta property="og:title" content="<%= typeof pageTitle !== 'undefined' && pageTitle ? pageTitle : settings.company_short %>">
    <meta property="og:description" content="<%= settings.meta_description || '' %>">
    <meta property="og:type" content="website">
    <meta property="og:locale" content="<%= isEn ? 'en_US' : 'fa_IR' %>">
    <meta property="og:site_name" content="<%= settings.company_short %>">
    <meta property="og:image" content="/images/logo.jpg">

    <!-- Structured Data -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "<%= settings.company_name %>",
      "url": "https://proshut.com",
      "logo": "/images/logo.jpg",
      "contactPoint": { "@type": "ContactPoint", "telephone": "<%= settings.phone %>", "contactType": "customer service" },
      "address": { "@type": "PostalAddress", "addressLocality": "Mashhad", "addressCountry": "IR", "streetAddress": "<%= settings.address %>" }
    }
    </script>

    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin>
    <% if (isEn) { %>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <% } else { %>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.rtl.min.css">
    <% } %>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css">
    <link rel="stylesheet" href="https://unpkg.com/aos@2.3.4/dist/aos.css">
    <link rel="stylesheet" href="/css/style.css">
    <% if (isEn) { %>
    <style>body{direction:ltr;font-family:'Segoe UI','Helvetica Neue',Arial,sans-serif;text-align:left}
    .fa-arrow-left{transform:scaleX(-1)}
    .hero-slide{transform:scaleX(-1)}
    .hero-slide>.hero-overlay,.hero-slide>.container{transform:scaleX(-1)}
    .search-form button{order:1;border-radius:0 var(--radius-sm) var(--radius-sm) 0}
    .search-form input{border-radius:var(--radius-sm) 0 0 var(--radius-sm)}
    .lang-link[href="?lang=fa"]{font-family:'PeydaWeb',sans-serif}
    .heroSwiper .swiper-pagination{left:auto;right:60px}
    .showcase-layout{gap:28px}
    .showcase-products{padding:0 50px 0 0}
    .showcase-products-wrap::after{left:auto;right:0;background:linear-gradient(to left,var(--bg-light),transparent)}
    .showcase-products-wrap::before{right:auto;left:0;width:0}
    .showcase-scroll-right{right:6px}
    .showcase-scroll-left{left:6px}
    .cat-row a i{margin-left:0;margin-right:8px}
    .category-list li a i{margin-left:0;margin-right:8px}
    .footer-widget h4::after{right:auto;left:0}
    </style>
    <% } %>
</head>
<body>
    <!-- Top Loading Bar -->
    <div class="top-loader" id="topLoader"></div>

    <!-- Preloader -->
    <div class="preloader" id="preloader">
        <div class="spinner"></div>
    </div>

    <!-- Top Bar -->
    <div class="site-header-wrap<%= (typeof breadcrumbs !== 'undefined' && breadcrumbs && breadcrumbs.length) ? ' has-breadcrumb' : '' %>">
    <div class="top-bar">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-md-6 col-12">
                    <div class="top-bar-info">
                        <a href="mailto:<%= settings.email %>"><i class="fas fa-envelope"></i> <%= settings.email %></a>
                        <a href="tel:<%= settings.phone %>"><i class="fas fa-phone-alt"></i> <span dir="ltr"><%= settings.phone %></span></a>
                    </div>
                </div>
                <div class="col-md-6 d-none d-md-block text-start">
                    <div class="top-bar-social">
                        <% if (settings.instagram) { %><a href="<%= settings.instagram %>" target="_blank" rel="noopener" aria-label="Instagram"><i class="fab fa-instagram"></i></a><% } %>
                        <% if (settings.telegram) { %><a href="<%= settings.telegram %>" target="_blank" rel="noopener" aria-label="Telegram"><i class="fab fa-telegram"></i></a><% } %>
                        <% if (settings.linkedin) { %><a href="<%= settings.linkedin %>" target="_blank" rel="noopener" aria-label="LinkedIn"><i class="fab fa-linkedin-in"></i></a><% } %>
                        <% if (settings.whatsapp) { %><a href="https://wa.me/<%= settings.whatsapp %>" target="_blank" rel="noopener" aria-label="WhatsApp"><i class="fab fa-whatsapp"></i></a><% } %>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Header -->
    <header class="main-header d-none d-lg-block">
        <div class="container">
            <div class="row align-items-center py-3">
                <div class="col-lg-8 d-flex align-items-center gap-4">
                    <a href="/" class="logo" aria-label="<%= t('home') %>">
                        <img src="/images/logo.jpg" alt="<%= settings.company_short %>" class="logo-img" width="190" height="65">
                    </a>
                    <% if (typeof breadcrumbs !== 'undefined' && breadcrumbs && breadcrumbs.length) { %>
                    <nav class="breadcrumb-nav header-breadcrumb">
                        <a href="/"><%= t('home') %></a>
                        <% breadcrumbs.forEach(function(bc) { %>
                            <span>/</span>
                            <% if (bc.url) { %>
                                <a href="<%= bc.url %>"><%= bc.label %></a>
                            <% } else { %>
                                <span class="current"><%= bc.label %></span>
                            <% } %>
                        <% }); %>
                    </nav>
                    <% } %>
                </div>
                <div class="col-lg-4 text-start d-flex align-items-center justify-content-end">
                    <div class="top-bar-lang">
                        <a href="?lang=fa" class="lang-link <%= !isEn ? 'active' : '' %>">فارسی</a>
                        <span class="lang-divider">|</span>
                        <a href="?lang=en" class="lang-link <%= isEn ? 'active' : '' %>">English</a>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <!-- Nav -->
    <nav class="navbar navbar-expand-lg main-nav" id="mainNavbar">
        <div class="container">
            <a class="navbar-brand d-lg-none" href="/">
                <img src="/images/logo.jpg" alt="<%= settings.company_short %>" height="40">
            </a>
            <div class="d-lg-none mobile-lang-switch">
                <a href="?lang=fa" class="lang-link <%= !isEn ? 'active' : '' %>">فارسی</a>
                <span class="lang-divider">|</span>
                <a href="?lang=en" class="lang-link <%= isEn ? 'active' : '' %>">English</a>
            </div>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav" aria-label="Menu">
                <i class="fas fa-bars"></i>
            </button>
            <div class="collapse navbar-collapse" id="mainNav">
                <ul class="navbar-nav">
                    <li class="nav-item"><a class="nav-link <%= currentPath === '/' ? 'active' : '' %>" href="/"><i class="fas fa-home"></i> <%= t('home') %></a></li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="/products" data-bs-toggle="dropdown"><i class="fas fa-box"></i> <%= t('products') %></a>
                        <ul class="dropdown-menu">
                            <li><a class="dropdown-item" href="/products"><%= t('all_products') %></a></li>
                            <li><hr class="dropdown-divider"></li>
                            <% categories.forEach(cat => { %>
                            <li><a class="dropdown-item" href="/products?category=<%= cat.slug %>"><i class="<%= cat.icon %> me-2"></i><%= cat.name %></a></li>
                            <% }); %>
                        </ul>
                    </li>
                    <li class="nav-item"><a class="nav-link <%= currentPath === '/services' ? 'active' : '' %>" href="/services"><i class="fas fa-concierge-bell"></i> <%= t('services') %></a></li>
                    <li class="nav-item"><a class="nav-link <%= currentPath === '/blog' ? 'active' : '' %>" href="/blog"><i class="fas fa-newspaper"></i> <%= t('academy') %></a></li>
                    <li class="nav-item"><a class="nav-link <%= currentPath === '/projects' ? 'active' : '' %>" href="/projects"><i class="fas fa-project-diagram"></i> <%= t('projects') %></a></li>
                    <li class="nav-item"><a class="nav-link <%= currentPath === '/about' ? 'active' : '' %>" href="/about"><i class="fas fa-info-circle"></i> <%= t('about') %></a></li>
                    <li class="nav-item"><a class="nav-link <%= currentPath === '/contact' ? 'active' : '' %>" href="/contact"><i class="fas fa-phone"></i> <%= t('contact') %></a></li>
                </ul>
                <div class="nav-extra nav-extra-fullwidth">
                    <form class="search-form search-form-fullwidth" action="/search" method="GET">
                        <button type="submit"><i class="fas fa-search"></i></button>
                        <input type="search" name="q" placeholder="<%= t('search_placeholder') %>" aria-label="Search">
                    </form>
                </div>
            </div>
        </div>
    </nav>
    </div><!-- /site-header-wrap -->

    <main>
