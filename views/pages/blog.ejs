<%- include('../partials/header') %>

<!-- Page Header -->
<section class="page-header">
    <div class="container">
        <nav class="breadcrumb-nav">
            <a href="/"><%= t('home') %></a>
            <span>/</span>
            <span class="current"><%= t('academy') %></span>
        </nav>
    </div>
</section>

<!-- Blog Section -->
<section class="section-padding">
    <div class="container">
        <div class="section-header text-center mb-5" data-aos="fade-up">
            <span class="section-badge"><%= t('academy') %></span>
            <h2 class="section-title"><%= t('articles') %></h2>
            <div class="section-divider"></div>
            <p class="section-desc mt-3"><%= t('articles_desc') %></p>
        </div>

        <% if (posts.length === 0) { %>
        <div class="text-center py-5" data-aos="fade-up">
            <i class="fas fa-newspaper" style="font-size: 4rem; color: var(--border-color); margin-bottom: 20px;"></i>
            <h4 style="color: var(--text-light);"><%= t('no_articles') %></h4>
            <p class="text-muted"><%= t('no_articles_desc') %></p>
        </div>
        <% } else { %>
        <div class="row g-4">
            <% posts.forEach((post, i) => { %>
            <div class="col-lg-4 col-md-6" data-aos="fade-up" data-aos-delay="<%= (i % 3) * 100 %>">
                <article class="blog-card">
                    <div class="blog-image">
                        <img src="<%= post.image %>" alt="<%= post.title %>" loading="lazy" onerror="this.src='https://images.unsplash.com/photo-1572883454114-1cf0031ede2a?w=600&q=80'">
                        <div class="blog-image-overlay"></div>
                        <span class="blog-date"><%= new Date(post.created_at).toLocaleDateString(isEn ? 'en-US' : 'fa-IR') %></span>
                        <% if (post.category) { %>
                        <span class="blog-category-badge"><%= post.category %></span>
                        <% } %>
                    </div>
                    <div class="blog-info">
                        <h5><a href="/blog/<%= post.slug %>"><%= post.title %></a></h5>
                        <p><%= post.excerpt %></p>
                        <a href="/blog/<%= post.slug %>" class="blog-read-more"><%= t('read_article') %> <i class="fas fa-arrow-<%= isEn ? 'right' : 'left' %> ms-1"></i></a>
                    </div>
                </article>
            </div>
            <% }); %>
        </div>
        <% } %>
    </div>
</section>

<%- include('../partials/footer') %>
