<!-- Featured Products -->
<section class="products-showcase section-padding">
    <div class="container">
        <!-- Layout: Description Right + Products Left -->
        <div class="showcase-layout" data-aos="fade-up">
            <!-- Right side: Category description -->
            <div class="showcase-description">
                <div class="showcase-desc-inner" id="showcaseDesc">
                    <div class="showcase-desc-icon"><i class="fas fa-boxes"></i></div>
                    <h3><%= t('proshut_products') %></h3>
                    <p><%= settings.about_short || '' %></p>
                    <div class="showcase-desc-stats">
                        <div class="showcase-stat">
                            <strong><%= settings.years_experience || (isEn ? '15+' : '۱۵+') %></strong>
                            <span><%= t('years_exp') %></span>
                        </div>
                        <div class="showcase-stat">
                            <strong><%= settings.projects_done || (isEn ? '500+' : '۵۰۰+') %></strong>
                            <span><%= t('successful_projects') %></span>
                        </div>
                    </div>
                    <a href="/products" class="btn btn-primary btn-sm mt-2"><%= t('view_all_products') %> <i class="fas fa-arrow-left ms-2"></i></a>
                </div>
            </div>

            <!-- Scroll right button (between cards) -->
            <button class="showcase-scroll-btn showcase-scroll-right" id="showcaseScrollRight" aria-label="<%= t('scroll_right') %>"><i class="fas fa-chevron-right"></i></button>

            <!-- Left side: Scrollable products -->
            <div class="showcase-products-wrap">
                <button class="showcase-scroll-btn showcase-scroll-left" id="showcaseScrollLeft" aria-label="<%= t('scroll_left') %>"><i class="fas fa-chevron-left"></i></button>
                <div class="showcase-products" id="showcaseProducts">
                    <% featuredProducts.forEach((product, i) => { %>
                    <article class="showcase-product-card">
                        <div class="product-image">
                            <img src="<%= product.image %>" alt="<%= product.name %>" loading="lazy" onerror="this.src='/images/no-image.svg'">
                            <div class="product-overlay">
                                <a href="/product/<%= product.slug %>" class="btn btn-light btn-sm"><%= t('view_details') %></a>
                            </div>
                            <% if (product.is_featured) { %><span class="product-badge"><%= t('featured') %></span><% } %>
                            <% if (product.special_status && product.special_status.trim()) { %>
                            <span class="product-badge" style="top: auto; bottom: 10px; background: #17a2b8;"><%= product.special_status %></span>
                            <% } %>
                        </div>
                        <div class="product-info">
                            <span class="product-category"><%= product.category_name %></span>
                            <h5><a href="/product/<%= product.slug %>"><%= product.name %></a></h5>
                            <% if (product.short_description) { %>
                            <p class="product-short-desc"><%= product.short_description %></p>
                            <% } %>
                            <% if (product.product_code) { %>
                            <small class="product-code"><%= t('code') %>: <span dir="ltr"><%= product.product_code %></span></small>
                            <% } %>
                        </div>
                    </article>
                    <% }); %>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Categories Banner -->
<section class="categories-section">
    <div class="container position-relative" style="z-index:2">
        <div class="section-header text-center text-white mb-5" data-aos="fade-up">
            <span class="section-badge section-badge-light"><%= t('categories_title') %></span>
            <h2 class="section-title text-white"><%= t('our_specialties') %></h2>
        </div>
        <div class="row g-4">
            <% categories.slice(0, 4).forEach((cat, i) => { %>
            <div class="col-lg-3 col-md-6" data-aos="zoom-in" data-aos-delay="<%= i * 100 %>">
                <a href="/products?category=<%= cat.slug %>" class="category-card">
                    <div class="category-icon"><i class="<%= cat.icon %>"></i></div>
                    <h5><%= cat.name %></h5>
                    <p><%= cat.description %></p>
                    <span class="category-arrow"><i class="fas fa-arrow-left"></i></span>
                </a>
            </div>
            <% }); %>
        </div>
    </div>
</section>

<!-- Projects -->
<% if (projects.length > 0) { %>
<section class="projects-home-section">
    <div class="container">
        <div class="projects-layout">
            <!-- Right side: Text -->
            <div class="projects-desc" data-aos="fade-left">
                <span class="section-badge"><%= t('our_projects') %></span>
                <h2 class="section-title"><%= t('successful_projects_title') %></h2>
                <div class="section-divider" style="margin:0 0 20px"></div>
                <p class="projects-desc-text"><%= t('projects_desc') %></p>
                <div class="projects-desc-stats">
                    <div class="projects-stat-item">
                        <strong><%= settings.projects_done || (isEn ? '500+' : '۵۰۰+') %></strong>
                        <span><%= t('successful_projects') %></span>
                    </div>
                    <div class="projects-stat-item">
                        <strong><%= settings.happy_clients || (isEn ? '300+' : '۳۰۰+') %></strong>
                        <span><%= t('happy_clients') %></span>
                    </div>
                </div>
                <a href="/projects" class="btn btn-primary btn-sm mt-4"><%= t('view_all_projects') %> <i class="fas fa-arrow-left ms-2"></i></a>
            </div>
            <!-- Left side: 2x2 grid -->
            <div class="projects-grid" data-aos="fade-right">
                <% projects.slice(0, 4).forEach((proj, i) => { %>
                <div class="project-window-card">
                    <img src="<%= proj.image %>" alt="<%= proj.title %>" loading="lazy" onerror="this.src='https://images.unsplash.com/photo-1564429238961-244d2be59e1e?w=600&q=80'">
                    <div class="project-overlay"></div>
                    <button class="project-share-btn" onclick="shareProject(this)" data-title="<%= proj.title %>" data-url="<%= '/projects#' + proj.slug %>" aria-label="<%= t('share') %>"><i class="fas fa-share-alt"></i></button>
                    <div class="project-window-info">
                        <h5><%= proj.title %></h5>
                        <p><%= proj.client %></p>
                    </div>
                </div>
                <% }); %>
            </div>
        </div>
    </div>
