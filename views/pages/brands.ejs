<%- include('../partials/header') %>

<!-- Page Header -->
<section class="page-header">
    <div class="container">
        <nav class="breadcrumb-nav">
            <a href="/"><%= t('home') %></a>
            <span>/</span>
            <span class="current"><%= isEn ? 'Brands' : 'نمایندگی‌ها' %></span>
        </nav>
    </div>
</section>

<!-- Brands Intro -->
<section class="section-padding">
    <div class="container">
        <div class="section-header text-center" data-aos="fade-up">
            <span class="section-badge"><%= isEn ? 'Business Partners' : 'شرکای تجاری' %></span>
            <h2 class="section-title"><%= isEn ? 'Official Representative of Prestigious International Brands' : 'نمایندگی رسمی برندهای معتبر بین‌المللی' %></h2>
            <div class="section-divider"></div>
            <p class="section-desc mt-3"><%= isEn ? settings.company_short + ' as an official representative of prestigious international brands, offers original products with valid warranties to the Iranian market.' : settings.company_short + ' به عنوان نماینده رسمی برندهای معتبر بین‌المللی، محصولات اصل و با گارانتی معتبر را به بازار ایران ارائه می‌دهد.' %></p>
        </div>
    </div>
</section>

<!-- Brands List -->
<section class="section-padding bg-light" style="padding-top: 0;">
    <div class="container">
        <% if (brands.length === 0) { %>
        <div class="text-center py-5" data-aos="fade-up">
            <i class="fas fa-award" style="font-size: 4rem; color: var(--border-color); margin-bottom: 20px;"></i>
            <h4 style="color: var(--text-light);"><%= isEn ? 'Brand information is currently being updated.' : 'در حال حاضر اطلاعات نمایندگی‌ها در حال به‌روزرسانی است.' %></h4>
        </div>
        <% } else { %>
        <div class="row g-4">
            <% brands.forEach((brand, i) => { %>
            <div class="col-lg-4 col-md-6" data-aos="fade-up" data-aos-delay="<%= (i % 3) * 100 %>">
                <div style="background: #fff; border-radius: var(--radius); box-shadow: var(--shadow); overflow: hidden; height: 100%; transition: var(--transition); border: 1px solid var(--border-color);"
                     onmouseover="this.style.transform='translateY(-5px)'; this.style.boxShadow='var(--shadow-hover)'; this.style.borderColor='var(--primary-color)';"
                     onmouseout="this.style.transform='none'; this.style.boxShadow='var(--shadow)'; this.style.borderColor='var(--border-color)';">
                    <div style="background: var(--bg-light); padding: 30px; text-align: center; min-height: 150px; display: flex; align-items: center; justify-content: center;">
                        <% if (brand.logo) { %>
                        <img src="<%= brand.logo %>" alt="<%= brand.name %>" style="max-height: 80px; max-width: 200px; object-fit: contain;" loading="lazy" onerror="this.parentElement.innerHTML='<h3 style=color:var(--primary-color);font-weight:900;><%= brand.name %></h3>'">
                        <% } else { %>
                        <h3 style="color: var(--primary-color); font-weight: 900;"><%= brand.name %></h3>
                        <% } %>
                    </div>
                    <div style="padding: 25px;">
                        <h5 style="font-weight: 700; margin-bottom: 8px;"><%= brand.name %></h5>
                        <% if (brand.country) { %>
                        <p style="color: var(--primary-color); font-size: 0.85rem; margin-bottom: 10px;"><i class="fas fa-globe me-1"></i><%= brand.country %></p>
                        <% } %>
                        <% if (brand.description) { %>
                        <p class="text-muted" style="font-size: 0.9rem; line-height: 1.8;"><%= brand.description %></p>
                        <% } %>
                        <% if (brand.website) { %>
                        <a href="<%= brand.website %>" target="_blank" rel="noopener" style="color: var(--primary-color); font-weight: 600; font-size: 0.9rem;">
                            <i class="fas fa-external-link-alt me-1"></i><%= isEn ? 'Official Website' : 'وب‌سایت رسمی' %>
                        </a>
                        <% } %>
                    </div>
                </div>
            </div>
            <% }); %>
        </div>
        <% } %>
    </div>
</section>

<!-- CTA -->
<section class="section-padding">
    <div class="container">
        <div class="cta-section text-center" data-aos="fade-up">
            <div class="row align-items-center justify-content-center">
                <div class="col-lg-8">
                    <h3><%= isEn ? 'Looking for a specific product?' : 'محصول خاصی مد نظر دارید؟' %></h3>
                    <p><%= isEn ? 'Our sales team is ready to consult and offer the best products from trusted brands' : 'تیم فروش ما آماده مشاوره و ارائه بهترین محصولات از برندهای معتبر است' %></p>
                    <div class="d-flex justify-content-center gap-3 mt-3 flex-wrap">
                        <a href="/products" class="btn btn-lg"><i class="fas fa-box me-2"></i><%= isEn ? 'View Products' : 'مشاهده محصولات' %></a>
                        <a href="/contact" class="btn btn-lg" style="background: var(--secondary-color); color: #fff;"><i class="fas fa-phone-alt me-2"></i><%= isEn ? 'Contact Us' : 'تماس با ما' %></a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<%- include('../partials/footer') %>
