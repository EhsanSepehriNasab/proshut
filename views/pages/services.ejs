<%- include('../partials/header') %>

<!-- Page Header -->
<section class="page-header">
    <div class="container">
        <nav class="breadcrumb-nav">
            <a href="/"><%= t('home') %></a>
            <span>/</span>
            <span class="current"><%= t('services') %></span>
        </nav>
    </div>
</section>

<!-- Services Intro -->
<section class="section-padding">
    <div class="container">
        <div class="section-header text-center" data-aos="fade-up">
            <span class="section-badge"><%= t('our_services_title') %></span>
            <h2 class="section-title"><%= t('our_services_title') %> <%= settings.company_short %></h2>
            <div class="section-divider"></div>
            <p class="section-desc mt-3"><%= t('services_page_desc') %></p>
        </div>
    </div>
</section>

<!-- Services List -->
<section class="section-padding bg-light" style="padding-top: 0;">
    <div class="container">
        <div class="row g-4">
            <% services.forEach((service, i) => { %>
            <div class="col-lg-4 col-md-6" data-aos="fade-up" data-aos-delay="<%= (i % 3) * 100 %>">
                <div class="service-card-lg">
                    <span class="service-number"><%= isEn ? '0' + (i + 1) : '۰' + (i + 1) %></span>
                    <div class="service-icon-lg">
                        <i class="<%= service.icon %>"></i>
                    </div>
                    <h4><%= service.title %></h4>
                    <p><%= service.description %></p>
                    <% if (service.long_description) { %>
                    <div class="mt-3">
                        <a class="card-link" data-bs-toggle="collapse" href="#serviceDetail<%= i %>" role="button" aria-expanded="false">
                            <%= t('more_details') %> <i class="fas fa-chevron-down ms-1" style="font-size: 0.7rem;"></i>
                        </a>
                        <div class="collapse mt-3" id="serviceDetail<%= i %>">
                            <p class="text-muted" style="font-size: 0.9rem; line-height: 2;"><%- service.long_description %></p>
                        </div>
                    </div>
                    <% } %>
                </div>
            </div>
            <% }); %>
        </div>
    </div>
</section>

<!-- Service Features -->
<section class="section-padding" style="padding-top:60px">
    <div class="container">
        <div class="row align-items-center g-5">
            <div class="col-lg-5" data-aos="fade-left">
                <div class="medal-wrapper">
                    <i class="fas fa-medal medal-bg"></i>
                    <div class="medal-logo">
                        <img src="/images/logo.jpg" alt="<%= settings.company_short %>">
                        <div class="medal-shine"></div>
                    </div>
                </div>
            </div>
            <div class="col-lg-7" data-aos="fade-right">
                <span class="section-badge"><%= t('why_us') %></span>
                <h2 class="section-title"><%= t('service_advantages') %></h2>
                <div class="section-divider"></div>
                <div class="mt-4">
                    <div class="d-flex align-items-start gap-3 mb-4">
                        <div style="min-width: 50px; height: 50px; background: var(--primary-color); border-radius: 50%; display: flex; align-items: center; justify-content: center;">
                            <i class="fas fa-certificate" style="color: #fff; font-size: 1.2rem;"></i>
                        </div>
                        <div>
                            <h5 style="font-weight: 700;"><%= t('guaranteed_quality') %></h5>
                            <p class="text-muted mb-0"><%= t('guaranteed_quality_desc') %></p>
                        </div>
                    </div>
                    <div class="d-flex align-items-start gap-3 mb-4">
                        <div style="min-width: 50px; height: 50px; background: var(--primary-color); border-radius: 50%; display: flex; align-items: center; justify-content: center;">
                            <i class="fas fa-users-cog" style="color: #fff; font-size: 1.2rem;"></i>
                        </div>
                        <div>
                            <h5 style="font-weight: 700;"><%= t('expert_team') %></h5>
                            <p class="text-muted mb-0"><%= t('expert_team_desc') %></p>
                        </div>
                    </div>
                    <div class="d-flex align-items-start gap-3 mb-4">
                        <div style="min-width: 50px; height: 50px; background: var(--primary-color); border-radius: 50%; display: flex; align-items: center; justify-content: center;">
                            <i class="fas fa-clock" style="color: #fff; font-size: 1.2rem;"></i>
                        </div>
                        <div>
                            <h5 style="font-weight: 700;"><%= t('support_24') %></h5>
                            <p class="text-muted mb-0"><%= t('support_24_desc') %></p>
                        </div>
                    </div>
                    <div class="d-flex align-items-start gap-3">
                        <div style="min-width: 50px; height: 50px; background: var(--primary-color); border-radius: 50%; display: flex; align-items: center; justify-content: center;">
                            <i class="fas fa-hand-holding-usd" style="color: #fff; font-size: 1.2rem;"></i>
                        </div>
                        <div>
                            <h5 style="font-weight: 700;"><%= t('fair_price') %></h5>
                            <p class="text-muted mb-0"><%= t('fair_price_desc') %></p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- CTA Section -->
<section class="section-padding bg-light">
    <div class="container">
        <div class="cta-section text-center" data-aos="fade-up">
            <div class="row align-items-center justify-content-center">
                <div class="col-lg-8">
                    <h3><%= t('need_consulting_cta') %></h3>
                    <p><%= t('consulting_cta_desc') %></p>
                    <div class="d-flex justify-content-center gap-3 mt-3 flex-wrap">
                        <a href="/contact" class="btn btn-lg"><i class="fas fa-phone-alt me-2"></i><%= t('contact_us') %></a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<%- include('../partials/footer') %>
