<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>مدیریت دسته‌بندی‌ها</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.rtl.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/rastikerdar/vazirmatn@v33.003/Vazirmatn-font-face.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link rel="stylesheet" href="/css/admin.css">
</head>
<body>
    <aside class="sidebar">
        <div class="sidebar-logo">
            <h4>پروشات</h4>
            <small>پنل مدیریت</small>
        </div>
        <ul class="sidebar-menu">
            <li><a href="/admin/dashboard" class="<%= page === 'dashboard' ? 'active' : '' %>"><i class="fas fa-home"></i> داشبورد</a></li>
            <li><a href="/admin/products" class="<%= page === 'products' ? 'active' : '' %>"><i class="fas fa-box"></i> محصولات</a></li>
            <li><a href="/admin/categories" class="<%= page === 'categories' ? 'active' : '' %>"><i class="fas fa-folder"></i> دسته‌بندی‌ها</a></li>
            <li><a href="/admin/projects" class="<%= page === 'projects' ? 'active' : '' %>"><i class="fas fa-project-diagram"></i> پروژه‌ها</a></li>
            <li><a href="/admin/contacts" class="<%= page === 'contacts' ? 'active' : '' %>"><i class="fas fa-envelope"></i> پیام‌ها</a></li>
            <li><a href="/admin/tickets" class="<%= page === 'tickets' ? 'active' : '' %>"><i class="fas fa-ticket"></i> تیکت‌ها</a></li>
            <li><a href="/admin/blog" class="<%= page === 'blog' ? 'active' : '' %>"><i class="fas fa-newspaper"></i> مقالات</a></li>
            <li><a href="/admin/sliders" class="<%= page === 'sliders' ? 'active' : '' %>"><i class="fas fa-images"></i> اسلایدر</a></li>
            <li><a href="/admin/brands" class="<%= page === 'brands' ? 'active' : '' %>"><i class="fas fa-copyright"></i> برندها</a></li>
            <li><a href="/admin/newsletter" class="<%= page === 'newsletter' ? 'active' : '' %>"><i class="fas fa-bell"></i> خبرنامه</a></li>
            <li><a href="/admin/settings" class="<%= page === 'settings' ? 'active' : '' %>"><i class="fas fa-cog"></i> تنظیمات</a></li>
            <li><a href="/admin/logout"><i class="fas fa-sign-out-alt"></i> خروج</a></li>
        </ul>
    </aside>

    <div class="main-content">
        <div class="topbar">
            <div class="page-title">مدیریت دسته‌بندی‌ها</div>
            <div class="admin-info">
                <span class="admin-name"><i class="fas fa-user-circle"></i> <%= admin %></span>
                <a href="/admin/logout" class="btn-logout"><i class="fas fa-sign-out-alt"></i> خروج</a>
            </div>
        </div>

        <div class="content-area">
            <div class="row g-4">
                <!-- Add Category Form -->
                <div class="col-lg-4">
                    <div class="card card-custom">
                        <div class="card-header">افزودن دسته‌بندی</div>
                        <div class="card-body">
                            <form action="/admin/categories" method="POST">
                                <div class="mb-3">
                                    <label class="form-label">نام دسته‌بندی</label>
                                    <input type="text" class="form-control" name="name" required>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">اسلاگ (URL)</label>
                                    <input type="text" class="form-control" name="slug" dir="ltr">
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">دسته‌بندی والد <small class="text-muted">(اختیاری - برای زیردسته)</small></label>
                                    <select class="form-select" name="parent_id">
                                        <option value="">— دسته اصلی —</option>
                                        <% if (parentCategories && parentCategories.length > 0) { %>
                                            <% parentCategories.forEach(function(cat) { %>
                                                <option value="<%= cat.id %>"><%= cat.name %></option>
                                            <% }); %>
                                        <% } %>
                                    </select>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">آیکون <small class="text-muted">(Font Awesome)</small></label>
                                    <input type="text" class="form-control" name="icon" dir="ltr" placeholder="fas fa-folder">
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">توضیحات</label>
                                    <textarea class="form-control" name="description" rows="3"></textarea>
                                </div>
                                <hr>
                                <h6 class="mb-3"><i class="fas fa-globe me-1"></i> English</h6>
                                <div class="mb-3">
                                    <label class="form-label">Category Name (EN)</label>
                                    <input type="text" class="form-control" name="name_en" dir="ltr">
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Description (EN)</label>
                                    <textarea class="form-control" name="description_en" rows="2" dir="ltr"></textarea>
                                </div>
                                <button type="submit" class="btn btn-accent w-100">
                                    <i class="fas fa-plus me-1"></i> افزودن
                                </button>
                            </form>
                        </div>
                    </div>
                </div>

                <!-- Categories List -->
                <div class="col-lg-8">
                    <div class="card card-custom">
                        <div class="card-header">لیست دسته‌بندی‌ها</div>
                        <div class="card-body p-0">
                            <div class="table-responsive">
                                <table class="table table-hover mb-0">
                                    <thead>
                                        <tr>
                                            <th>#</th>
                                            <th>نام</th>
                                            <th>اسلاگ</th>
                                            <th>نوع</th>
                                            <th>توضیحات</th>
                                            <th>عملیات</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% if (parentCategories && parentCategories.length > 0) { %>
                                            <% let rowNum = 1; %>
                                            <% parentCategories.forEach(function(cat) { %>
                                                <tr style="background: #f8f9fa;">
                                                    <td><%= rowNum++ %></td>
                                                    <td><strong><i class="fas fa-folder me-1" style="color: var(--primary-color);"></i><%= cat.name %></strong></td>
                                                    <td><span dir="ltr" class="text-muted"><%= cat.slug || '-' %></span></td>
                                                    <td><span class="badge-status" style="background:#e8f5e9;color:#2e7d32;">اصلی</span></td>
                                                    <td><%= cat.description ? cat.description.substring(0, 40) + '...' : '-' %></td>
                                                    <td>
                                                        <button class="btn-action text-white me-1" style="background: #3498db;"
                                                            data-bs-toggle="modal" data-bs-target="#editCategoryModal"
                                                            onclick="fillEditCategory(<%= JSON.stringify(cat).replace(/</g,'\\u003c') %>)">
                                                            <i class="fas fa-edit"></i>
                                                        </button>
                                                        <form action="/admin/categories/<%= cat.id %>/delete" method="POST" style="display:inline;" onsubmit="return confirm('آیا از حذف این دسته‌بندی مطمئن هستید؟')">
                                                            <button type="submit" class="btn-action text-white" style="background: #e74c3c;">
                                                                <i class="fas fa-trash"></i>
                                                            </button>
                                                        </form>
                                                    </td>
                                                </tr>
                                                <% if (cat.subcategories && cat.subcategories.length > 0) { %>
                                                    <% cat.subcategories.forEach(function(sub) { %>
                                                    <tr>
                                                        <td><%= rowNum++ %></td>
                                                        <td style="padding-right: 30px;"><i class="fas fa-angle-left me-1 text-muted"></i><%= sub.name %></td>
                                                        <td><span dir="ltr" class="text-muted"><%= sub.slug || '-' %></span></td>
                                                        <td><span class="badge-status" style="background:#e3f2fd;color:#1565c0;">زیردسته</span></td>
                                                        <td><%= sub.description ? sub.description.substring(0, 40) + '...' : '-' %></td>
                                                        <td>
                                                            <button class="btn-action text-white me-1" style="background: #3498db;"
                                                                data-bs-toggle="modal" data-bs-target="#editCategoryModal"
                                                                onclick="fillEditCategory(<%= JSON.stringify(sub).replace(/</g,'\\u003c') %>)">
                                                                <i class="fas fa-edit"></i>
                                                            </button>
                                                            <form action="/admin/categories/<%= sub.id %>/delete" method="POST" style="display:inline;" onsubmit="return confirm('آیا از حذف این دسته‌بندی مطمئن هستید؟')">
                                                                <button type="submit" class="btn-action text-white" style="background: #e74c3c;">
                                                                    <i class="fas fa-trash"></i>
                                                                </button>
                                                            </form>
                                                        </td>
                                                    </tr>
                                                    <% }); %>
                                                <% } %>
                                            <% }); %>
                                        <% } else { %>
                                            <tr><td colspan="6" class="text-center text-muted py-4">دسته‌بندی‌ای وجود ندارد</td></tr>
                                        <% } %>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Edit Category Modal -->
    <div class="modal fade" id="editCategoryModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" style="font-weight: 700;">ویرایش دسته‌بندی</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <form id="editCategoryForm" method="POST">
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label">نام دسته‌بندی</label>
                            <input type="text" class="form-control" name="name" id="editCatName" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">اسلاگ (URL)</label>
                            <input type="text" class="form-control" name="slug" id="editCatSlug" dir="ltr">
                        </div>
                        <div class="mb-3">
                            <label class="form-label">دسته‌بندی والد</label>
                            <select class="form-select" name="parent_id" id="editCatParent">
                                <option value="">— دسته اصلی —</option>
                                <% if (parentCategories && parentCategories.length > 0) { %>
                                    <% parentCategories.forEach(function(cat) { %>
                                        <option value="<%= cat.id %>"><%= cat.name %></option>
                                    <% }); %>
                                <% } %>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">آیکون</label>
                            <input type="text" class="form-control" name="icon" id="editCatIcon" dir="ltr">
                        </div>
                        <div class="mb-3">
                            <label class="form-label">توضیحات</label>
                            <textarea class="form-control" name="description" id="editCatDescription" rows="3"></textarea>
                        </div>
                        <hr>
                        <h6 class="mb-3"><i class="fas fa-globe me-1"></i> English</h6>
                        <div class="mb-3">
                            <label class="form-label">Category Name (EN)</label>
                            <input type="text" class="form-control" name="name_en" id="editCatNameEn" dir="ltr">
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Description (EN)</label>
                            <textarea class="form-control" name="description_en" id="editCatDescEn" rows="2" dir="ltr"></textarea>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">انصراف</button>
                        <button type="submit" class="btn btn-accent">بروزرسانی</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function fillEditCategory(cat) {
            document.getElementById('editCategoryForm').action = '/admin/categories/' + cat.id + '/edit';
            document.getElementById('editCatName').value = cat.name || '';
            document.getElementById('editCatSlug').value = cat.slug || '';
            document.getElementById('editCatDescription').value = cat.description || '';
            document.getElementById('editCatIcon').value = cat.icon || '';
            document.getElementById('editCatParent').value = cat.parent_id || '';
            document.getElementById('editCatNameEn').value = cat.name_en || '';
            document.getElementById('editCatDescEn').value = cat.description_en || '';
        }
    </script>
</body>
</html>
