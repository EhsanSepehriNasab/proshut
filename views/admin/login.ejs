<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ورود به پنل مدیریت</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.rtl.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/rastikerdar/vazirmatn@v33.003/Vazirmatn-font-face.css">
    <style>
        * { font-family: 'Vazirmatn', sans-serif; }
        body {
            background: linear-gradient(135deg, #121111 0%, #1a1917 50%, #0f0f0e 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .login-card {
            background: #fff;
            border-radius: 16px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.3);
            padding: 40px;
            width: 100%;
            max-width: 420px;
        }
        .login-card h2 {
            color: #121111;
            font-weight: 800;
            margin-bottom: 8px;
        }
        .login-card p.subtitle {
            color: #888;
            font-size: 14px;
            margin-bottom: 30px;
        }
        .login-logo {
            width: 60px;
            height: 60px;
            background: #ADAB15;
            border-radius: 14px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 20px;
            color: #fff;
            font-size: 28px;
            font-weight: 900;
        }
        .form-control {
            border-radius: 10px;
            padding: 12px 16px;
            border: 2px solid #e9ecef;
            font-size: 14px;
            transition: border-color 0.3s;
        }
        .form-control:focus {
            border-color: #ADAB15;
            box-shadow: 0 0 0 0.2rem rgba(173,171,21,0.15);
        }
        .form-label {
            font-weight: 600;
            color: #444;
            font-size: 13px;
        }
        .btn-login {
            background: #ADAB15;
            border: none;
            border-radius: 10px;
            padding: 12px;
            font-size: 15px;
            font-weight: 700;
            color: #121111;
            width: 100%;
            transition: background 0.3s;
        }
        .btn-login:hover {
            background: #8E8C10;
            color: #121111;
        }
        .alert-danger {
            border-radius: 10px;
            font-size: 13px;
            border: none;
            background: #ffeaea;
            color: #c0392b;
        }
    </style>
</head>
<body>
    <div class="login-card">
        <div class="login-logo">PS</div>
        <h2 class="text-center">پنل مدیریت</h2>
        <p class="subtitle text-center">لطفا وارد حساب کاربری خود شوید</p>

        <% if (typeof error !== 'undefined' && error) { %>
            <div class="alert alert-danger text-center">
                <%= error %>
            </div>
        <% } %>

        <form method="POST" action="/admin/login">
            <div class="mb-3">
                <label for="username" class="form-label">نام کاربری</label>
                <input type="text" class="form-control" id="username" name="username" placeholder="نام کاربری خود را وارد کنید" required autofocus>
            </div>
            <div class="mb-4">
                <label for="password" class="form-label">رمز عبور</label>
                <input type="password" class="form-control" id="password" name="password" placeholder="رمز عبور خود را وارد کنید" required>
            </div>
            <button type="submit" class="btn btn-login">ورود به پنل</button>
        </form>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
