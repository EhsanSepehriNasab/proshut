<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>جزئیات تیکت</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.rtl.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/rastikerdar/vazirmatn@v33.003/Vazirmatn-font-face.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link rel="stylesheet" href="/css/admin.css">
</head>
<body>
    <aside class="sidebar">
        <div class="sidebar-logo">
            <h4>پروشات</h4>
            <small>پنل مدیریت</small>
        </div>
        <ul class="sidebar-menu">
            <li><a href="/admin/dashboard" class="<%= page === 'dashboard' ? 'active' : '' %>"><i class="fas fa-home"></i> داشبورد</a></li>
            <li><a href="/admin/products" class="<%= page === 'products' ? 'active' : '' %>"><i class="fas fa-box"></i> محصولات</a></li>
            <li><a href="/admin/categories" class="<%= page === 'categories' ? 'active' : '' %>"><i class="fas fa-folder"></i> دسته‌بندی‌ها</a></li>
            <li><a href="/admin/projects" class="<%= page === 'projects' ? 'active' : '' %>"><i class="fas fa-project-diagram"></i> پروژه‌ها</a></li>
            <li><a href="/admin/contacts" class="<%= page === 'contacts' ? 'active' : '' %>"><i class="fas fa-envelope"></i> پیام‌ها</a></li>
            <li><a href="/admin/tickets" class="<%= page === 'tickets' ? 'active' : '' %>"><i class="fas fa-ticket"></i> تیکت‌ها</a></li>
            <li><a href="/admin/blog" class="<%= page === 'blog' ? 'active' : '' %>"><i class="fas fa-newspaper"></i> مقالات</a></li>
            <li><a href="/admin/sliders" class="<%= page === 'sliders' ? 'active' : '' %>"><i class="fas fa-images"></i> اسلایدر</a></li>
            <li><a href="/admin/brands" class="<%= page === 'brands' ? 'active' : '' %>"><i class="fas fa-copyright"></i> برندها</a></li>
            <li><a href="/admin/newsletter" class="<%= page === 'newsletter' ? 'active' : '' %>"><i class="fas fa-bell"></i> خبرنامه</a></li>
            <li><a href="/admin/settings" class="<%= page === 'settings' ? 'active' : '' %>"><i class="fas fa-cog"></i> تنظیمات</a></li>
            <li><a href="/admin/logout"><i class="fas fa-sign-out-alt"></i> خروج</a></li>
        </ul>
    </aside>

    <div class="main-content">
        <div class="topbar">
            <div class="page-title">جزئیات تیکت</div>
            <div class="admin-info">
                <span class="admin-name"><i class="fas fa-user-circle"></i> <%= admin %></span>
                <a href="/admin/logout" class="btn-logout"><i class="fas fa-sign-out-alt"></i> خروج</a>
            </div>
        </div>

        <div class="content-area">
            <div class="mb-3">
                <a href="/admin/tickets" class="text-decoration-none link-accent">
                    <i class="fas fa-arrow-right me-1"></i> بازگشت به لیست تیکت‌ها
                </a>
            </div>

            <div class="row g-4">
                <!-- Ticket Info & Messages -->
                <div class="col-lg-8">
                    <!-- Ticket Info -->
                    <div class="card card-custom mb-4">
                        <div class="card-header d-flex justify-content-between align-items-center">
                            <span>اطلاعات تیکت</span>
                            <% if (ticket.status === 'open') { %>
                                <span class="badge-status" style="background: #fff3e0; color: #e65100;">باز</span>
                            <% } else if (ticket.status === 'answered') { %>
                                <span class="badge-status" style="background: #e8f5e9; color: #2e7d32;">پاسخ داده شده</span>
                            <% } else { %>
                                <span class="badge-status" style="background: #eceff1; color: #546e7a;">بسته شده</span>
                            <% } %>
                        </div>
                        <div class="card-body">
                            <div class="detail-row">
                                <div class="detail-label">نام:</div>
                                <div class="detail-value"><%= ticket.name %></div>
                            </div>
                            <div class="detail-row">
                                <div class="detail-label">ایمیل:</div>
                                <div class="detail-value" dir="ltr" style="text-align: right;"><%= ticket.email %></div>
                            </div>
                            <div class="detail-row">
                                <div class="detail-label">موضوع:</div>
                                <div class="detail-value"><%= ticket.subject %></div>
                            </div>
                            <div class="detail-row">
                                <div class="detail-label">تاریخ:</div>
                                <div class="detail-value"><%= new Date(ticket.created_at).toLocaleDateString('fa-IR') %></div>
                            </div>
                        </div>
                    </div>

                    <!-- Messages -->
                    <div class="card card-custom mb-4">
                        <div class="card-header">مکالمات</div>
                        <div class="card-body">
                            <!-- Original message -->
                            <div class="message-bubble message-user">
                                <div class="message-sender" style="color: #3498db;">
                                    <i class="fas fa-user"></i> <%= ticket.name %>
                                    <span class="message-date me-2"><%= new Date(ticket.created_at).toLocaleDateString('fa-IR') %></span>
                                </div>
                                <div><%= ticket.message %></div>
                            </div>

                            <!-- Replies -->
                            <% if (ticket.replies && ticket.replies.length > 0) { %>
                                <% ticket.replies.forEach(function(reply) { %>
                                    <div class="message-bubble <%= reply.is_admin ? 'message-admin' : 'message-user' %>">
                                        <div class="message-sender" style="color: <%= reply.is_admin ? '#ADAB15' : '#3498db' %>;">
                                            <i class="fas <%= reply.is_admin ? 'fa-user-shield' : 'fa-user' %>"></i>
                                            <%= reply.is_admin ? 'مدیر' : ticket.name %>
                                            <span class="message-date me-2"><%= new Date(reply.created_at).toLocaleDateString('fa-IR') %></span>
                                        </div>
                                        <div><%= reply.message %></div>
                                    </div>
                                <% }); %>
                            <% } %>
                        </div>
                    </div>

                    <!-- Reply Form -->
                    <% if (ticket.status !== 'closed') { %>
                        <div class="card card-custom">
                            <div class="card-header">ارسال پاسخ</div>
                            <div class="card-body">
                                <form action="/admin/tickets/<%= ticket.id %>/reply" method="POST">
                                    <div class="mb-3">
                                        <textarea class="form-control" name="message" rows="5" placeholder="پاسخ خود را بنویسید..." required></textarea>
                                    </div>
                                    <button type="submit" class="btn btn-accent">
                                        <i class="fas fa-paper-plane me-1"></i> ارسال پاسخ
                                    </button>
                                </form>
                            </div>
                        </div>
                    <% } %>
                </div>

                <!-- Status Change -->
                <div class="col-lg-4">
                    <div class="card card-custom">
                        <div class="card-header">تغییر وضعیت</div>
                        <div class="card-body">
                            <form action="/admin/tickets/<%= ticket.id %>/status" method="POST">
                                <div class="mb-3">
                                    <label class="form-label">وضعیت تیکت</label>
                                    <select class="form-select" name="status" required>
                                        <option value="open" <%= ticket.status === 'open' ? 'selected' : '' %>>باز</option>
                                        <option value="answered" <%= ticket.status === 'answered' ? 'selected' : '' %>>پاسخ داده شده</option>
                                        <option value="closed" <%= ticket.status === 'closed' ? 'selected' : '' %>>بسته شده</option>
                                    </select>
                                </div>
                                <button type="submit" class="btn btn-accent w-100">
                                    <i class="fas fa-sync me-1"></i> بروزرسانی وضعیت
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
