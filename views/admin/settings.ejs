<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>تنظیمات سایت</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.rtl.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/rastikerdar/vazirmatn@v33.003/Vazirmatn-font-face.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link rel="stylesheet" href="/css/admin.css">
</head>
<body>
    <aside class="sidebar">
        <div class="sidebar-logo">
            <h4>پروشات</h4>
            <small>پنل مدیریت</small>
        </div>
        <ul class="sidebar-menu">
            <li><a href="/admin/dashboard" class="<%= page === 'dashboard' ? 'active' : '' %>"><i class="fas fa-home"></i> داشبورد</a></li>
            <li><a href="/admin/products" class="<%= page === 'products' ? 'active' : '' %>"><i class="fas fa-box"></i> محصولات</a></li>
            <li><a href="/admin/categories" class="<%= page === 'categories' ? 'active' : '' %>"><i class="fas fa-folder"></i> دسته‌بندی‌ها</a></li>
            <li><a href="/admin/projects" class="<%= page === 'projects' ? 'active' : '' %>"><i class="fas fa-project-diagram"></i> پروژه‌ها</a></li>
            <li><a href="/admin/contacts" class="<%= page === 'contacts' ? 'active' : '' %>"><i class="fas fa-envelope"></i> پیام‌ها</a></li>
            <li><a href="/admin/tickets" class="<%= page === 'tickets' ? 'active' : '' %>"><i class="fas fa-ticket"></i> تیکت‌ها</a></li>
            <li><a href="/admin/blog" class="<%= page === 'blog' ? 'active' : '' %>"><i class="fas fa-newspaper"></i> مقالات</a></li>
            <li><a href="/admin/sliders" class="<%= page === 'sliders' ? 'active' : '' %>"><i class="fas fa-images"></i> اسلایدر</a></li>
            <li><a href="/admin/brands" class="<%= page === 'brands' ? 'active' : '' %>"><i class="fas fa-copyright"></i> برندها</a></li>
            <li><a href="/admin/newsletter" class="<%= page === 'newsletter' ? 'active' : '' %>"><i class="fas fa-bell"></i> خبرنامه</a></li>
            <li><a href="/admin/settings" class="<%= page === 'settings' ? 'active' : '' %>"><i class="fas fa-cog"></i> تنظیمات</a></li>
            <li><a href="/admin/logout"><i class="fas fa-sign-out-alt"></i> خروج</a></li>
        </ul>
    </aside>

    <div class="main-content">
        <div class="topbar">
            <div class="page-title">تنظیمات سایت</div>
            <div class="admin-info">
                <span class="admin-name"><i class="fas fa-user-circle"></i> <%= admin %></span>
                <a href="/admin/logout" class="btn-logout"><i class="fas fa-sign-out-alt"></i> خروج</a>
            </div>
        </div>

        <div class="content-area">
            <% if (typeof success !== 'undefined' && success) { %>
                <div class="alert alert-success">
                    <i class="fas fa-check-circle me-1"></i> <%= success %>
                </div>
            <% } %>

            <form action="/admin/settings" method="POST" enctype="multipart/form-data">
                <div class="row g-4">
                    <!-- General Info -->
                    <div class="col-lg-6">
                        <div class="card card-custom">
                            <div class="card-header">اطلاعات عمومی</div>
                            <div class="card-body">
                                <div class="mb-3">
                                    <label class="form-label">نام شرکت / سایت</label>
                                    <input type="text" class="form-control" name="site_name" value="<%= (settings && settings.site_name) || '' %>">
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">شعار سایت</label>
                                    <input type="text" class="form-control" name="site_tagline" value="<%= (settings && settings.site_tagline) || '' %>">
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">توضیحات سایت</label>
                                    <textarea class="form-control" name="site_description" rows="3"><%= (settings && settings.site_description) || '' %></textarea>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">لوگوی سایت</label>
                                    <input type="file" class="form-control" name="logo" accept="image/*">
                                    <% if (settings && settings.logo) { %>
                                        <small class="text-muted mt-1 d-block">فایل فعلی: <%= settings.logo %></small>
                                    <% } %>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">فاوآیکون</label>
                                    <input type="file" class="form-control" name="favicon" accept="image/*">
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Contact Info -->
                    <div class="col-lg-6">
                        <div class="card card-custom">
                            <div class="card-header">اطلاعات تماس</div>
                            <div class="card-body">
                                <div class="mb-3">
                                    <label class="form-label">شماره تلفن</label>
                                    <input type="text" class="form-control" name="phone" dir="ltr" value="<%= (settings && settings.phone) || '' %>">
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">شماره موبایل</label>
                                    <input type="text" class="form-control" name="mobile" dir="ltr" value="<%= (settings && settings.mobile) || '' %>">
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">ایمیل</label>
                                    <input type="email" class="form-control" name="email" dir="ltr" value="<%= (settings && settings.email) || '' %>">
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">آدرس</label>
                                    <textarea class="form-control" name="address" rows="2"><%= (settings && settings.address) || '' %></textarea>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">ساعات کاری</label>
                                    <input type="text" class="form-control" name="working_hours" value="<%= (settings && settings.working_hours) || '' %>" placeholder="مثلا: شنبه تا پنجشنبه ۹ تا ۱۸">
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Social Media -->
                    <div class="col-lg-6">
                        <div class="card card-custom">
                            <div class="card-header">شبکه‌های اجتماعی</div>
                            <div class="card-body">
                                <div class="mb-3">
                                    <label class="form-label"><i class="fab fa-instagram me-1"></i> اینستاگرام</label>
                                    <input type="url" class="form-control" name="instagram" dir="ltr" value="<%= (settings && settings.instagram) || '' %>" placeholder="https://instagram.com/...">
                                </div>
                                <div class="mb-3">
                                    <label class="form-label"><i class="fab fa-telegram me-1"></i> تلگرام</label>
                                    <input type="url" class="form-control" name="telegram" dir="ltr" value="<%= (settings && settings.telegram) || '' %>" placeholder="https://t.me/...">
                                </div>
                                <div class="mb-3">
                                    <label class="form-label"><i class="fab fa-whatsapp me-1"></i> واتساپ</label>
                                    <input type="text" class="form-control" name="whatsapp" dir="ltr" value="<%= (settings && settings.whatsapp) || '' %>" placeholder="09xxxxxxxxx">
                                </div>
                                <div class="mb-3">
                                    <label class="form-label"><i class="fab fa-linkedin me-1"></i> لینکدین</label>
                                    <input type="url" class="form-control" name="linkedin" dir="ltr" value="<%= (settings && settings.linkedin) || '' %>" placeholder="https://linkedin.com/...">
                                </div>
                                <div class="mb-3">
                                    <label class="form-label"><i class="fab fa-twitter me-1"></i> توییتر / ایکس</label>
                                    <input type="url" class="form-control" name="twitter" dir="ltr" value="<%= (settings && settings.twitter) || '' %>" placeholder="https://x.com/...">
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- SEO & Meta -->
                    <div class="col-lg-6">
                        <div class="card card-custom">
                            <div class="card-header">تنظیمات سئو</div>
                            <div class="card-body">
                                <div class="mb-3">
                                    <label class="form-label">عنوان متا</label>
                                    <input type="text" class="form-control" name="meta_title" value="<%= (settings && settings.meta_title) || '' %>">
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">توضیحات متا</label>
                                    <textarea class="form-control" name="meta_description" rows="3"><%= (settings && settings.meta_description) || '' %></textarea>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">کلمات کلیدی</label>
                                    <input type="text" class="form-control" name="meta_keywords" value="<%= (settings && settings.meta_keywords) || '' %>" placeholder="کلمات را با کاما جدا کنید">
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">کد Google Analytics</label>
                                    <input type="text" class="form-control" name="google_analytics" dir="ltr" value="<%= (settings && settings.google_analytics) || '' %>" placeholder="UA-XXXXXXXX-X">
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">متن فوتر (کپی‌رایت)</label>
                                    <input type="text" class="form-control" name="footer_text" value="<%= (settings && settings.footer_text) || '' %>">
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="row g-4 mt-2">
                    <!-- English Texts -->
                    <div class="col-lg-6">
                        <div class="card card-custom">
                            <div class="card-header"><i class="fas fa-globe me-1"></i> English Texts</div>
                            <div class="card-body">
                                <div class="mb-3">
                                    <label class="form-label">Company Name (EN)</label>
                                    <input type="text" class="form-control" name="company_name_en" dir="ltr" value="<%= (settings && settings.company_name_en) || '' %>">
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Company Short Name (EN)</label>
                                    <input type="text" class="form-control" name="company_short_en" dir="ltr" value="<%= (settings && settings.company_short_en) || '' %>">
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">About Short (EN)</label>
                                    <textarea class="form-control" name="about_short_en" dir="ltr" rows="3"><%= (settings && settings.about_short_en) || '' %></textarea>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">About Full Text (EN)</label>
                                    <textarea class="form-control" name="about_text_en" dir="ltr" rows="4"><%= (settings && settings.about_text_en) || '' %></textarea>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-6">
                        <div class="card card-custom">
                            <div class="card-header"><i class="fas fa-globe me-1"></i> English Info & SEO</div>
                            <div class="card-body">
                                <div class="mb-3">
                                    <label class="form-label">Address (EN)</label>
                                    <textarea class="form-control" name="address_en" dir="ltr" rows="2"><%= (settings && settings.address_en) || '' %></textarea>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Working Hours (EN)</label>
                                    <input type="text" class="form-control" name="working_hours_en" dir="ltr" value="<%= (settings && settings.working_hours_en) || '' %>">
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Meta Title (EN)</label>
                                    <input type="text" class="form-control" name="meta_title_en" dir="ltr" value="<%= (settings && settings.meta_title_en) || '' %>">
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Meta Description (EN)</label>
                                    <textarea class="form-control" name="meta_description_en" dir="ltr" rows="2"><%= (settings && settings.meta_description_en) || '' %></textarea>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">About Vision (EN)</label>
                                    <input type="text" class="form-control" name="about_vision_en" dir="ltr" value="<%= (settings && settings.about_vision_en) || '' %>">
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="mt-4 text-start">
                    <button type="submit" class="btn btn-accent btn-lg">
                        <i class="fas fa-save me-1"></i> ذخیره تنظیمات
                    </button>
                </div>
            </form>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
