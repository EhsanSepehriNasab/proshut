<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>مدیریت پروژه‌ها</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.rtl.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/rastikerdar/vazirmatn@v33.003/Vazirmatn-font-face.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link rel="stylesheet" href="/css/admin.css">
</head>
<body>
    <aside class="sidebar">
        <div class="sidebar-logo">
            <h4>پروشات</h4>
            <small>پنل مدیریت</small>
        </div>
        <ul class="sidebar-menu">
            <li><a href="/admin/dashboard" class="<%= page === 'dashboard' ? 'active' : '' %>"><i class="fas fa-home"></i> داشبورد</a></li>
            <li><a href="/admin/products" class="<%= page === 'products' ? 'active' : '' %>"><i class="fas fa-box"></i> محصولات</a></li>
            <li><a href="/admin/categories" class="<%= page === 'categories' ? 'active' : '' %>"><i class="fas fa-folder"></i> دسته‌بندی‌ها</a></li>
            <li><a href="/admin/projects" class="<%= page === 'projects' ? 'active' : '' %>"><i class="fas fa-project-diagram"></i> پروژه‌ها</a></li>
            <li><a href="/admin/contacts" class="<%= page === 'contacts' ? 'active' : '' %>"><i class="fas fa-envelope"></i> پیام‌ها</a></li>
            <li><a href="/admin/tickets" class="<%= page === 'tickets' ? 'active' : '' %>"><i class="fas fa-ticket"></i> تیکت‌ها</a></li>
            <li><a href="/admin/blog" class="<%= page === 'blog' ? 'active' : '' %>"><i class="fas fa-newspaper"></i> مقالات</a></li>
            <li><a href="/admin/sliders" class="<%= page === 'sliders' ? 'active' : '' %>"><i class="fas fa-images"></i> اسلایدر</a></li>
            <li><a href="/admin/brands" class="<%= page === 'brands' ? 'active' : '' %>"><i class="fas fa-copyright"></i> برندها</a></li>
            <li><a href="/admin/newsletter" class="<%= page === 'newsletter' ? 'active' : '' %>"><i class="fas fa-bell"></i> خبرنامه</a></li>
            <li><a href="/admin/settings" class="<%= page === 'settings' ? 'active' : '' %>"><i class="fas fa-cog"></i> تنظیمات</a></li>
            <li><a href="/admin/logout"><i class="fas fa-sign-out-alt"></i> خروج</a></li>
        </ul>
    </aside>

    <div class="main-content">
        <div class="topbar">
            <div class="page-title">مدیریت پروژه‌ها</div>
            <div class="admin-info">
                <span class="admin-name"><i class="fas fa-user-circle"></i> <%= admin %></span>
                <a href="/admin/logout" class="btn-logout"><i class="fas fa-sign-out-alt"></i> خروج</a>
            </div>
        </div>

        <div class="content-area">
            <div class="row g-4">
                <!-- Add/Edit Project Form -->
                <div class="col-lg-5">
                    <div class="card card-custom">
                        <div class="card-header" id="formHeader">افزودن پروژه جدید</div>
                        <div class="card-body">
                            <form action="/admin/projects" method="POST" enctype="multipart/form-data" id="projectForm">
                                <input type="hidden" name="_method" id="formMethod" value="create">
                                <div class="mb-3">
                                    <label class="form-label">عنوان پروژه</label>
                                    <input type="text" class="form-control" name="title" id="title" required>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">اسلاگ (URL)</label>
                                    <input type="text" class="form-control" name="slug" id="slug" dir="ltr">
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">کارفرما</label>
                                    <input type="text" class="form-control" name="client" id="client">
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">سال اجرا</label>
                                    <input type="text" class="form-control" name="year" id="year" placeholder="مثلا: ۱۴۰۳">
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">توضیحات</label>
                                    <textarea class="form-control" name="description" id="description" rows="3"></textarea>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">تصویر</label>
                                    <input type="file" class="form-control" name="image" accept="image/*">
                                    <div id="currentImage" class="mt-2" style="display:none;">
                                        <small class="text-muted">تصویر فعلی:</small>
                                        <img id="currentImagePreview" src="" alt="" style="max-height:60px;border-radius:6px;margin-top:4px;display:block;">
                                    </div>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">ترتیب نمایش</label>
                                    <input type="number" class="form-control" name="sort_order" id="sort_order" value="0">
                                </div>
                                <div class="mb-3 form-check form-switch">
                                    <input type="checkbox" class="form-check-input" name="is_active" id="is_active" checked>
                                    <label class="form-check-label" for="is_active">فعال</label>
                                </div>
                                <hr>
                                <h6 class="mb-3"><i class="fas fa-globe me-1"></i> English</h6>
                                <div class="mb-3">
                                    <label class="form-label">Project Title (EN)</label>
                                    <input type="text" class="form-control" name="title_en" id="title_en" dir="ltr">
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Client (EN)</label>
                                    <input type="text" class="form-control" name="client_en" id="client_en" dir="ltr">
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Description (EN)</label>
                                    <textarea class="form-control" name="description_en" id="description_en" rows="3" dir="ltr"></textarea>
                                </div>
                                <button type="submit" class="btn btn-accent w-100" id="submitBtn">
                                    <i class="fas fa-plus me-1"></i> افزودن پروژه
                                </button>
                                <button type="button" class="btn btn-secondary w-100 mt-2" id="cancelEdit" style="display:none;" onclick="resetForm()">
                                    <i class="fas fa-times me-1"></i> انصراف
                                </button>
                            </form>
                        </div>
                    </div>
                </div>

                <!-- Projects List -->
                <div class="col-lg-7">
                    <div class="card card-custom">
                        <div class="card-header">لیست پروژه‌ها (<%= projects.length %>)</div>
                        <div class="card-body p-0">
                            <div class="table-responsive">
                                <table class="table table-hover mb-0">
                                    <thead>
                                        <tr>
                                            <th>#</th>
                                            <th>تصویر</th>
                                            <th>عنوان</th>
                                            <th>کارفرما</th>
                                            <th>سال</th>
                                            <th>وضعیت</th>
                                            <th>عملیات</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% if (projects && projects.length > 0) { %>
                                            <% projects.forEach(function(proj, index) { %>
                                                <tr>
                                                    <td><%= index + 1 %></td>
                                                    <td>
                                                        <% if (proj.image) { %>
                                                            <img src="<%= proj.image %>" alt="" style="width:50px;height:35px;object-fit:cover;border-radius:4px;" onerror="this.src='/images/no-image.svg'">
                                                        <% } else { %>
                                                            <span class="text-muted">-</span>
                                                        <% } %>
                                                    </td>
                                                    <td><%= proj.title %></td>
                                                    <td><%= proj.client || '-' %></td>
                                                    <td><%= proj.year || '-' %></td>
                                                    <td>
                                                        <span class="badge bg-<%= proj.is_active ? 'success' : 'secondary' %>">
                                                            <%= proj.is_active ? 'فعال' : 'غیرفعال' %>
                                                        </span>
                                                    </td>
                                                    <td>
                                                        <button type="button" class="btn-action text-white me-1" style="background: #3498db;"
                                                            data-id="<%= proj.id %>"
                                                            data-title="<%- proj.title.replace(/"/g, '&quot;') %>"
                                                            data-slug="<%- proj.slug %>"
                                                            data-client="<%- (proj.client || '').replace(/"/g, '&quot;') %>"
                                                            data-year="<%- proj.year || '' %>"
                                                            data-description="<%- (proj.description || '').replace(/"/g, '&quot;') %>"
                                                            data-image="<%- proj.image || '' %>"
                                                            data-sort="<%= proj.sort_order || 0 %>"
                                                            data-active="<%= proj.is_active %>"
                                                            data-title-en="<%- (proj.title_en || '').replace(/"/g, '&quot;') %>"
                                                            data-client-en="<%- (proj.client_en || '').replace(/"/g, '&quot;') %>"
                                                            data-description-en="<%- (proj.description_en || '').replace(/"/g, '&quot;') %>"
                                                            onclick="editFromBtn(this)">
                                                            <i class="fas fa-edit"></i>
                                                        </button>
                                                        <form action="/admin/projects/<%= proj.id %>/delete" method="POST" style="display:inline;" onsubmit="return confirm('آیا از حذف این پروژه مطمئن هستید؟')">
                                                            <button type="submit" class="btn-action text-white" style="background: #e74c3c;">
                                                                <i class="fas fa-trash"></i>
                                                            </button>
                                                        </form>
                                                    </td>
                                                </tr>
                                            <% }); %>
                                        <% } else { %>
                                            <tr><td colspan="7" class="text-center text-muted py-4">پروژه‌ای وجود ندارد</td></tr>
                                        <% } %>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
    function editFromBtn(btn) {
        var id = btn.getAttribute('data-id');
        var title = btn.getAttribute('data-title');
        document.getElementById('formHeader').textContent = 'ویرایش پروژه: ' + title;
        document.getElementById('projectForm').action = '/admin/projects/' + id + '/edit';
        document.getElementById('formMethod').value = 'edit';
        document.getElementById('title').value = title;
        document.getElementById('slug').value = btn.getAttribute('data-slug');
        document.getElementById('client').value = btn.getAttribute('data-client');
        document.getElementById('year').value = btn.getAttribute('data-year');
        document.getElementById('description').value = btn.getAttribute('data-description');
        document.getElementById('sort_order').value = btn.getAttribute('data-sort');
        document.getElementById('is_active').checked = btn.getAttribute('data-active') == '1';
        document.getElementById('title_en').value = btn.getAttribute('data-title-en');
        document.getElementById('client_en').value = btn.getAttribute('data-client-en');
        document.getElementById('description_en').value = btn.getAttribute('data-description-en');
        document.getElementById('submitBtn').innerHTML = '<i class="fas fa-save me-1"></i> ذخیره تغییرات';
        document.getElementById('cancelEdit').style.display = 'block';
        var img = btn.getAttribute('data-image');
        if (img) {
            document.getElementById('currentImage').style.display = 'block';
            document.getElementById('currentImagePreview').src = img;
        } else {
            document.getElementById('currentImage').style.display = 'none';
        }
        window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    function resetForm() {
        document.getElementById('formHeader').textContent = 'افزودن پروژه جدید';
        document.getElementById('projectForm').action = '/admin/projects';
        document.getElementById('formMethod').value = 'create';
        document.getElementById('projectForm').reset();
        document.getElementById('is_active').checked = true;
        document.getElementById('submitBtn').innerHTML = '<i class="fas fa-plus me-1"></i> افزودن پروژه';
        document.getElementById('cancelEdit').style.display = 'none';
        document.getElementById('currentImage').style.display = 'none';
    }
    </script>
</body>
</html>
