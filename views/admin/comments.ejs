<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>مدیریت نظرات</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.rtl.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/rastikerdar/vazirmatn@v33.003/Vazirmatn-font-face.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link rel="stylesheet" href="/css/admin.css">
</head>
<body>
    <aside class="sidebar">
        <div class="sidebar-logo">
            <h4>پروشات</h4>
            <small>پنل مدیریت</small>
        </div>
        <ul class="sidebar-menu">
            <li><a href="/admin/dashboard"><i class="fas fa-home"></i> داشبورد</a></li>
            <li><a href="/admin/products" class="active"><i class="fas fa-box"></i> محصولات</a></li>
            <li><a href="/admin/categories"><i class="fas fa-folder"></i> دسته‌بندی‌ها</a></li>
            <li><a href="/admin/projects" class="<%= page === 'projects' ? 'active' : '' %>"><i class="fas fa-project-diagram"></i> پروژه‌ها</a></li>
            <li><a href="/admin/contacts"><i class="fas fa-envelope"></i> پیام‌ها</a></li>
            <li><a href="/admin/tickets"><i class="fas fa-ticket"></i> تیکت‌ها</a></li>
            <li><a href="/admin/blog"><i class="fas fa-newspaper"></i> مقالات</a></li>
            <li><a href="/admin/sliders"><i class="fas fa-images"></i> اسلایدر</a></li>
            <li><a href="/admin/brands"><i class="fas fa-copyright"></i> برندها</a></li>
            <li><a href="/admin/newsletter"><i class="fas fa-bell"></i> خبرنامه</a></li>
            <li><a href="/admin/settings"><i class="fas fa-cog"></i> تنظیمات</a></li>
            <li><a href="/admin/logout"><i class="fas fa-sign-out-alt"></i> خروج</a></li>
        </ul>
    </aside>

    <div class="main-content">
        <div class="topbar">
            <div class="page-title">مدیریت نظرات محصولات</div>
            <div class="admin-info">
                <span class="admin-name"><i class="fas fa-user-circle"></i> <%= admin %></span>
                <a href="/admin/logout" class="btn-logout"><i class="fas fa-sign-out-alt"></i> خروج</a>
            </div>
        </div>

        <div class="content-area">
            <div class="card card-custom">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <span>نظرات کاربران (<%= comments.filter(c => !c.is_approved).length %> در انتظار تأیید)</span>
                    <a href="/admin/products" class="btn btn-sm btn-outline-secondary"><i class="fas fa-arrow-right me-1"></i> بازگشت</a>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>نام</th>
                                    <th>نظر</th>
                                    <th>محصول</th>
                                    <th>امتیاز</th>
                                    <th>وضعیت</th>
                                    <th>تاریخ</th>
                                    <th>عملیات</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (comments && comments.length > 0) { %>
                                    <% comments.forEach(function(c, i) { %>
                                    <tr style="<%= !c.is_approved ? 'background:#fffde7;' : '' %>">
                                        <td><%= i + 1 %></td>
                                        <td>
                                            <strong><%= c.name %></strong>
                                            <% if (c.email) { %><br><small class="text-muted"><%= c.email %></small><% } %>
                                        </td>
                                        <td style="max-width:300px;">
                                            <div><%= c.comment.substring(0, 100) %><%= c.comment.length > 100 ? '...' : '' %></div>
                                            <% if (c.admin_reply) { %>
                                            <div style="margin-top:8px;padding:8px 10px;background:#e8f5e9;border-radius:6px;font-size:.82rem;border-right:3px solid #27ae60;">
                                                <strong style="color:#2e7d32;"><i class="fas fa-reply me-1"></i>پاسخ مدیر:</strong><br>
                                                <%= c.admin_reply %>
                                            </div>
                                            <% } %>
                                        </td>
                                        <td>
                                            <% if (c.product_name) { %>
                                            <a href="/product/<%= c.product_slug %>" target="_blank" class="text-decoration-none"><%= c.product_name %></a>
                                            <% } else { %>
                                            <span class="text-muted">-</span>
                                            <% } %>
                                        </td>
                                        <td>
                                            <% for(let r = 1; r <= 5; r++) { %>
                                            <i class="fas fa-star" style="color:<%= r <= c.rating ? '#f57f17' : '#ddd' %>;font-size:0.75rem;"></i>
                                            <% } %>
                                        </td>
                                        <td>
                                            <% if (c.is_approved) { %>
                                            <span class="badge-status" style="background:#e8f5e9;color:#2e7d32;">تأیید شده</span>
                                            <% } else { %>
                                            <span class="badge-status" style="background:#fff8e1;color:#f57f17;">در انتظار</span>
                                            <% } %>
                                        </td>
                                        <td><small class="text-muted"><%= new Date(c.created_at).toLocaleDateString('fa-IR') %></small></td>
                                        <td>
                                            <div class="d-flex gap-1 mb-1">
                                                <% if (!c.is_approved) { %>
                                                <form action="/admin/comments/<%= c.id %>/approve" method="POST" style="display:inline;">
                                                    <button type="submit" class="btn-action text-white" style="background:#27ae60;" title="تأیید">
                                                        <i class="fas fa-check"></i>
                                                    </button>
                                                </form>
                                                <% } %>
                                                <button class="btn-action text-white" style="background:#3498db;" title="پاسخ" onclick="document.getElementById('reply-<%= c.id %>').style.display=document.getElementById('reply-<%= c.id %>').style.display==='none'?'block':'none'">
                                                    <i class="fas fa-reply"></i>
                                                </button>
                                                <form action="/admin/comments/<%= c.id %>/delete" method="POST" style="display:inline;" onsubmit="return confirm('حذف شود؟')">
                                                    <button type="submit" class="btn-action text-white" style="background:#e74c3c;" title="حذف">
                                                        <i class="fas fa-trash"></i>
                                                    </button>
                                                </form>
                                            </div>
                                            <form id="reply-<%= c.id %>" action="/admin/comments/<%= c.id %>/reply" method="POST" style="display:none;">
                                                <textarea name="admin_reply" rows="2" class="form-control form-control-sm mb-1" placeholder="پاسخ شما..." style="font-size:.82rem;"><%= c.admin_reply || '' %></textarea>
                                                <button type="submit" class="btn btn-sm btn-primary" style="font-size:.75rem;"><i class="fas fa-paper-plane me-1"></i>ارسال پاسخ</button>
                                            </form>
                                        </td>
                                    </tr>
                                    <% }); %>
                                <% } else { %>
                                    <tr><td colspan="8" class="text-center text-muted py-4">نظری وجود ندارد</td></tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
